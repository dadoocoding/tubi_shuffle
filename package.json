{
  "name": "tubi-shuffle-tv",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome Manifest V3 extension that creates local pseudo-TV channels from official Tubi playback pages.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/chrome": "^0.0.320",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
